{
  "name": "gabriela-nunes-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:payload\"",
    "dev:next": "next dev",
    "dev:payload": "ts-node-dev --respawn --transpile-only ./payload/dev.ts",
    "build": "next build && tsc -p tsconfig.json",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "mark:docs": "node scripts/mark-docs-done.js"
  },
  "bin": {
    "mark-docs-done": "scripts/mark-docs-done.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "next": "latest",
    "payload": "^3.0.0",
    "react": "latest",
    "react-dom": "latest",
    "tailwindcss": "latest",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@payloadcms/db-mongodb": "^3.0.0",
    "@tailwindcss/postcss": "latest",
    "@types/express": "^4.17.17",
    "@types/react": "19.2.15",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "autoprefixer": "latest",
    "concurrently": "^7.6.0",
    "eslint": "latest",
    "eslint-plugin-react": "latest",
    "postcss": "latest",
    "prettier": "latest",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
